NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional model overrides. Use the exact model IDs available to your API account.
ANTHROPIC_REASONING_MODEL=claude-opus-4-8
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5
ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5
APP_PASSWORD=your_app_password
# Authorizes Vercel cron requests to /api/brief (sent as Authorization: Bearer).
CRON_SECRET=replace_with_a_long_random_value
# Goal-day and Daily Brief reset timezone.
LIFEOS_TIME_ZONE=Europe/Berlin
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Optional but recommended: set this to the exact callback URI registered in
# the WHOOP developer dashboard, for example http://localhost:3000/api/whoop-callback.
NEXT_PUBLIC_WHOOP_REDIRECT_URI=
# Server-only admin key used by cron and protected API routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Supabase Auth owner account — used to issue an authenticated session on login
# so RLS policies (auth.role() = 'authenticated') take effect in the browser client.
# Create a single user in Supabase Auth dashboard and put their credentials here.
# These are server-only (no NEXT_PUBLIC_ prefix) and never reach the browser.
SUPABASE_OWNER_EMAIL=your_supabase_owner_email
SUPABASE_OWNER_PASSWORD=your_supabase_owner_password
# MCP server bearer token — used by Claude chat (claude.ai) to authenticate.
# Generate: openssl rand -hex 32
MCP_API_KEY=replace_with_a_long_random_value
# Finances — market-data provider for ETF/stock quotes (crypto uses CoinGecko,
# which needs no key). Provider: "twelvedata" (default) or "finnhub".
MARKETDATA_PROVIDER=twelvedata
MARKETDATA_API_KEY=
# Currency used by the price-sync cron when valuing crypto. Default EUR.
MARKETDATA_BASE_CURRENCY=EUR
